---
import SiteLayout2 from "../layouts/SiteLayout2.astro";

const pageTranslations = {
  ru: {
    title: "Контакты",
    subtitle: "Каналы связи, социальные сети и рабочие контакты."
  },
  en: {
    title: "Contacts",
    subtitle: "Communication channels, social media and work contacts."
  },
  fr: {
    title: "Contacts",
    subtitle: "Canaux de communication, réseaux sociaux et contacts professionnels."
  }
};

const content = {
  ru: {
    introTitle: "Связь",
    introText:
      "Если у вас есть предложения по работе, стажировке или проектам в регионе Сахеля — напишите мне. Также буду признателен за контакты людей и организаций, работающих в этом регионе.",
    contactTitle: "Основные контакты",
    noteTitle: "Примечание",
    noteText:
      "По любым вопросам, связанным с Сахелем, можете связаться со мной. Открыт к предложениям, проектам и обмену контактами."
  },
  en: {
    introTitle: "Contact",
    introText:
      "If you have job opportunities, internships or projects in the Sahel region — feel free to contact me. I would also appreciate connections to people or organizations working in this region.",
    contactTitle: "Main contacts",
    noteTitle: "Note",
    noteText:
      "Feel free to contact me regarding anything related to the Sahel. Open to opportunities, projects and connections."
  },
  fr: {
    introTitle: "Contact",
    introText:
      "Si vous avez des opportunités de travail, des stages ou des projets dans la région du Sahel — contactez-moi. Je serais également reconnaissant pour tout contact avec des personnes ou des organisations actives dans cette région.",
    contactTitle: "Contacts principaux",
    noteTitle: "Note",
    noteText:
      "N’hésitez pas à me contacter pour toute question liée au Sahel. Ouvert aux opportunités, projets et contacts."
  }
};

const contacts = [
  {
    key: "telegram",
    icon: "TG",
    ruLabel: "Telegram",
    enLabel: "Telegram",
    frLabel: "Telegram",
    value: "@vt1hoy",
    href: "https://t.me/vt1hoy"
  },
  {
    key: "mail",
    icon: "ML",
    ruLabel: "Email",
    enLabel: "Email",
    frLabel: "Email",
    value: "petrov_msu@mail.ru",
    href: "mailto:petrov_msu@mail.ru"
  },
  {
    key: "x",
    icon: "X",
    ruLabel: "X / Twitter",
    enLabel: "X / Twitter",
    frLabel: "X / Twitter",
    value: "@vt1hoy",
    href: "https://x.com/vt1hoy"
  },
  {
    key: "instagram",
    icon: "IG",
    ruLabel: "Instagram",
    enLabel: "Instagram",
    frLabel: "Instagram",
    value: "@vt1hoy",
    href: "https://instagram.com/vt1hoy"
  },
  {
    key: "phone",
    icon: "PH",
    ruLabel: "Телефон",
    enLabel: "Phone",
    frLabel: "Téléphone",
    value: "+7 922 363-71-86",
    href: "tel:+79223637186"
  },
  {
    key: "linkedin",
    icon: "IN",
    ruLabel: "LinkedIn",
    enLabel: "LinkedIn",
    frLabel: "LinkedIn",
    value: "linkedin.com/in/yourprofile",
    href: "https://linkedin.com/in/yourprofile"
  }
];
---

<SiteLayout2 pageTranslations={pageTranslations}>
  <style>
    .contacts-layout {
      display: grid;
      grid-template-columns: 1.2fr 2fr;
      gap: 20px;
      margin-top: 24px;
    }

    .card {
      background: rgba(255, 255, 255, 0.96);
      border: 1px solid #d9e1ea;
      border-radius: 18px;
      padding: 22px;
      box-shadow: 0 8px 20px rgba(40, 60, 90, 0.05);
    }

    .card h2 {
      margin-top: 0;
      margin-bottom: 12px;
      color: #1d3d67;
    }

    .card p {
      margin: 0;
      line-height: 1.75;
      color: #425b78;
    }

    .contacts-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .contact-card {
      background: white;
      border: 1px solid #dde5ed;
      border-radius: 16px;
      padding: 18px;
      display: flex;
      gap: 14px;
      align-items: flex-start;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .contact-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 22px rgba(40, 60, 90, 0.08);
    }

    .contact-icon {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      background: #174b87;
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 800;
      flex-shrink: 0;
    }

    .contact-body {
      min-width: 0;
    }

    .contact-label {
      margin: 0 0 6px;
      font-size: 16px;
      font-weight: 700;
      color: #1d3d67;
    }

    .contact-link {
      color: #174b87;
      font-weight: 600;
      text-decoration: none;
      word-break: break-word;
    }

    .note-block {
      margin-top: 20px;
    }

    @media (max-width: 980px) {
      .contacts-layout {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 760px) {
      .contacts-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="contacts-layout">
    <div class="card">
      <h2 id="intro-title">{content.ru.introTitle}</h2>
      <p id="intro-text">{content.ru.introText}</p>

      <div class="note-block">
        <h2 id="note-title">{content.ru.noteTitle}</h2>
        <p id="note-text">{content.ru.noteText}</p>
      </div>
    </div>

    <div class="card">
      <h2 id="contacts-title">{content.ru.contactTitle}</h2>

      <div class="contacts-grid">
        {contacts.map((item) => (
          <a class="contact-card" href={item.href} target="_blank" rel="noopener noreferrer">
            <div class="contact-icon">{item.icon}</div>

            <div class="contact-body">
              <p
                class="contact-label"
                id={`contact-label-${item.key}`}
                data-ru={item.ruLabel}
                data-en={item.enLabel}
                data-fr={item.frLabel}
              >
                {item.ruLabel}
              </p>

              <span class="contact-link">{item.value}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <script define:vars={{ content }}>
    const LANG_KEY = "lang";

    function setContactsLang(lang) {
      const t = content[lang];
      if (!t) return;

      document.getElementById("intro-title").textContent = t.introTitle;
      document.getElementById("intro-text").textContent = t.introText;
      document.getElementById("contacts-title").textContent = t.contactTitle;
      document.getElementById("note-title").textContent = t.noteTitle;
      document.getElementById("note-text").textContent = t.noteText;

      document.querySelectorAll("[id^='contact-label-']").forEach((el) => {
        const value = el.dataset[lang];
        if (value) el.textContent = value;
      });
    }

    setContactsLang(localStorage.getItem(LANG_KEY) || "ru");

    window.addEventListener("languageChanged", (event) => {
      setContactsLang(event.detail.lang);
    });
  </script>
</SiteLayout2>