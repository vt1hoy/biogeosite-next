---
/**
 * Home page: GIS showcase cards (images/links) and per-locale copy.
 * Card order must match translations[].cards[] indices.
 */
const gisBlocks = [
  { image: "/images/dakar.jpg", link: "/dakar" },
  { image: "/images/bamako.jpg", link: "/bamako" },
  { image: "/images/ouagadougou.jpg", link: "/ouagadougou" },
  { image: "/images/niamey.jpg", link: "/niamey" },
  { image: "/images/fvp.jpg", link: "/uav" }
];

const translations = {
  ru: {
    brand: "BIOGEO PORTFOLIO",
    navContacts: "Контакты",
    heroTitle: "Приветствую! Я специалист по GIS и биогеографии.",
    heroSubtitle: "Исследую города, ресурсы и гуманитарные проекты в регионе Сахель.",
    heroBtnAbout: "Обо мне",
    heroBtnBiogeo: "Токен BIOGEO",
    heroBtnHumanitarian: "Гуманитарные миссии",
    heroBtnSenegalGis: "Данные GIS по Сенегалу",
    heroBtnNotcoin: "Notcoin Strategy",
    sectionTitle: "GIS НАВЫКИ",
    sectionSubtitle: "Мои проекты и исследования",
    cards: [
      { city: "Дакар", theme: "Урбанистика", desc: "Городская морфология, транспорт" },
      { city: "Бамако", theme: "Ресурсы", desc: "Полезные ископаемые, ресурсы" },
      { city: "Уагадугу", theme: "Сельское хозяйство", desc: "Агроанализ и землепользование" },
      { city: "Ниамей", theme: "Вода", desc: "Гидрология и водные ресурсы" },
      { city: "БПЛА", theme: "Дроны", desc: "Аэрофотосъёмка и мониторинг" }
    ]
  },

  en: {
    brand: "BIOGEO PORTFOLIO",
    navContacts: "Contacts",
    heroTitle: "Hello! I am a GIS and biogeography specialist.",
    heroSubtitle: "I work on cities, resources and humanitarian projects in the Sahel region.",
    heroBtnAbout: "About",
    heroBtnBiogeo: "BIOGEO Token",
    heroBtnSahel: "Sahel Plan",
    heroBtnHumanitarian: "Humanitarian Missions",
    heroBtnSenegalGis: "Senegal GIS Data",
    heroBtnNotcoin: "Notcoin Strategy",
    sectionTitle: "GIS SKILLS",
    sectionSubtitle: "My projects and research",
    cards: [
      { city: "Dakar", theme: "Urbanism", desc: "Urban morphology, transport" },
      { city: "Bamako", theme: "Resources", desc: "Minerals, resources" },
      { city: "Ouagadougou", theme: "Agriculture", desc: "Agri-analysis and land use" },
      { city: "Niamey", theme: "Water", desc: "Hydrology and water resources" },
      { city: "UAV", theme: "Drones", desc: "Aerial imagery and monitoring" }
    ]
  },

  fr: {
    brand: "BIOGEO PORTFOLIO",
    navContacts: "Contacts",
    heroTitle: "Bonjour ! Je suis spécialiste en SIG et biogéographie.",
    heroSubtitle: "J'étudie les villes, les ressources et les projets humanitaires dans la région du Sahel.",
    heroBtnAbout: "À propos",
    heroBtnBiogeo: "Jeton BIOGEO",
    heroBtnSahel: "Plan Sahel",
    heroBtnHumanitarian: "Missions humanitaires",
    heroBtnSenegalGis: "Données SIG Sénégal",
    heroBtnNotcoin: "Stratégie Notcoin",
    sectionTitle: "COMPÉTENCES GIS",
    sectionSubtitle: "Mes projets et recherches",
    cards: [
      { city: "Dakar", theme: "Urbanisme", desc: "Morphologie urbaine, transport" },
      { city: "Bamako", theme: "Ressources", desc: "Ressources minérales" },
      { city: "Ouagadougou", theme: "Agriculture", desc: "Agro-analyse et usage des terres" },
      { city: "Niamey", theme: "Eau", desc: "Hydrologie et ressources en eau" },
      { city: "UAV", theme: "Drones", desc: "Imagerie aérienne et suivi" }
    ]
  }
};
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{translations.ru.brand}</title>
    <style>
      :root {
        --bg: #eef2f6;
        --card: #ffffff;
        --text: #17365d;
        --muted: #5d6f86;
        --line: #d8dde5;
        --blue: #174b87;
        --shadow: 0 18px 45px rgba(31, 51, 81, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Inter, Arial, sans-serif;
        background: linear-gradient(180deg, #edf1f5 0%, #e7edf3 100%);
        color: var(--text);
      }

      a {
        text-decoration: none;
        color: inherit;
      }

      .shell {
        width: min(1340px, calc(100% - 40px));
        margin: 28px auto;
        background: rgba(255, 255, 255, 0.75);
        border: 1px solid rgba(210, 220, 230, 0.9);
        border-radius: 28px;
        box-shadow: var(--shadow);
        overflow: hidden;
        backdrop-filter: blur(6px);
      }

      .header {
        background: rgba(255, 255, 255, 0.82);
        border-bottom: 1px solid var(--line);
      }

      .header-inner {
        width: min(1240px, calc(100% - 48px));
        margin: 0 auto;
        min-height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }

      .brand {
        font-size: 24px;
        font-weight: 800;
        color: var(--blue);
        letter-spacing: -0.02em;
        text-transform: uppercase;
      }

      .nav-wrap {
        display: flex;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
      }

      .nav {
        display: flex;
        gap: 42px;
        flex-wrap: wrap;
      }

      .nav a {
        font-size: 16px;
        color: #50627b;
        font-weight: 600;
      }

      .lang-switcher {
        display: flex;
        gap: 8px;
      }

      .lang-btn {
        background: #eef3f8;
        color: var(--blue);
        border: 1px solid #d7e0ea;
        padding: 6px 10px;
        border-radius: 8px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 700;
      }

      .lang-btn.active {
        background: var(--blue);
        color: white;
        border-color: var(--blue);
      }

      .hero {
        text-align: center;
        padding-top: 56px;
        background:
          linear-gradient(
            180deg,
            rgba(255, 255, 255, 0.92) 0%,
            rgba(255, 255, 255, 0.82) 45%,
            rgba(255, 255, 255, 0.32) 100%
          ),
          url("/images/fon.jpg") center/cover no-repeat;
      }

      .hero-inner {
        width: min(1240px, calc(100% - 48px));
        margin: 0 auto;
      }

      h1 {
        margin: 0;
        font-size: clamp(34px, 4.3vw, 64px);
        line-height: 1.08;
        color: #243f67;
        letter-spacing: -0.03em;
      }

      .hero p {
        margin: 22px auto 0;
        max-width: 900px;
        font-size: 19px;
        line-height: 1.6;
        color: #5c6f87;
      }

      .hero-buttons {
        margin-top: 34px;
        display: flex;
        justify-content: center;
        gap: 14px;
        flex-wrap: wrap;
        padding-bottom: 42px;
      }

      .hero-btn {
        min-width: 220px;
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid #dbe1e8;
        border-radius: 14px;
        padding: 18px 22px;
        font-size: 17px;
        font-weight: 700;
        color: #24466f;
        box-shadow: 0 10px 24px rgba(40, 60, 90, 0.08);
      }

      .content {
        width: min(1240px, calc(100% - 48px));
        margin: 0 auto;
        padding: 36px 0 44px;
        background: #fff;
      }

      .section-head {
        display: flex;
        align-items: flex-end;
        gap: 18px;
        margin-bottom: 28px;
        flex-wrap: wrap;
      }

      .section-head h2 {
        margin: 0;
        font-size: 38px;
        line-height: 1;
        color: #1d3d67;
        letter-spacing: -0.03em;
      }

      .section-head p {
        margin: 0 0 4px;
        font-size: 16px;
        color: #61738b;
        font-weight: 600;
      }

      .cards {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 16px;
      }

      .project-card {
        position: relative;
        min-height: 360px;
        border-radius: 18px;
        overflow: hidden;
        background-size: cover;
        background-position: center;
        box-shadow: 0 12px 28px rgba(37, 57, 86, 0.16);
      }

      .project-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          180deg,
          rgba(10, 22, 35, 0.02) 0%,
          rgba(12, 25, 40, 0.36) 55%,
          rgba(15, 29, 45, 0.78) 100%
        );
      }

      .project-content {
        position: absolute;
        inset: auto 0 0 0;
        padding: 22px 20px 18px;
        color: #fff;
      }

      .project-content h3 {
        margin: 0;
        font-size: 26px;
        line-height: 1.05;
      }

      .project-theme {
        margin-top: 4px;
        font-size: 18px;
        font-weight: 700;
      }

      .project-line {
        width: 100%;
        height: 1px;
        margin: 18px 0 14px;
        background: rgba(255, 255, 255, 0.35);
      }

      .project-desc {
        font-size: 14px;
        line-height: 1.45;
        color: rgba(255, 255, 255, 0.92);
      }

      .cta-senegal-wrap {
        display: flex;
        justify-content: center;
        margin-top: 48px;
        margin-bottom: 12px;
        padding-top: 44px;
        border-top: 1px solid #e8edf3;
      }

      .cta-senegal-row {
        display: flex;
        justify-content: center;
        gap: 14px;
        flex-wrap: wrap;
      }

      .cta-senegal-wrap .cta-senegal-btn {
        --cta-senegal-pad-y: 24px;
        --cta-senegal-pad-x: 44px;
        min-width: 300px;
        padding: var(--cta-senegal-pad-y) var(--cta-senegal-pad-x);
        font-size: 18px;
        font-weight: 700;
        letter-spacing: -0.015em;
        line-height: 1.25;
        text-align: center;
        color: #fff;
        border-radius: 16px;
        border: 1px solid rgba(12, 40, 78, 0.45);
        background: linear-gradient(180deg, #1f5fa8 0%, var(--blue) 42%, #124a82 100%);
        box-shadow:
          0 16px 36px rgba(23, 75, 135, 0.32),
          0 6px 14px rgba(23, 75, 135, 0.2);
        transition:
          transform 0.2s ease,
          box-shadow 0.2s ease,
          background 0.2s ease,
          border-color 0.2s ease;
      }

      .cta-senegal-wrap .cta-senegal-btn:hover {
        transform: translateY(-2px);
        background: linear-gradient(180deg, #174b87 0%, #143d6e 55%, #0f3560 100%);
        box-shadow:
          0 20px 44px rgba(23, 75, 135, 0.38),
          0 8px 18px rgba(12, 40, 72, 0.28);
        border-color: rgba(8, 32, 62, 0.55);
      }

      .cta-senegal-wrap .cta-senegal-btn:active {
        transform: translateY(0);
        box-shadow:
          0 10px 24px rgba(23, 75, 135, 0.28),
          0 4px 10px rgba(23, 75, 135, 0.18);
      }

      .cta-senegal-wrap .cta-senegal-btn + .cta-senegal-btn {
        margin-left: 18px;
      }


      @media (max-width: 1200px) {
        .cards {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }
      }

      @media (max-width: 860px) {
        .header-inner {
          padding: 16px 0;
          align-items: flex-start;
          flex-direction: column;
        }

        .cards {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .hero-btn {
          min-width: 180px;
        }
      }

      @media (max-width: 560px) {
        .cards {
          grid-template-columns: 1fr;
        }

        .hero {
          padding-top: 36px;
        }

        h1 {
          font-size: 34px;
        }

        #hero-btn-sahel {
          display: none;
        }
      }
    </style>
  </head>

  <body>
    <div class="shell">
      <header class="header">
        <div class="header-inner">
          <div class="brand" id="brand">{translations.ru.brand}</div>

          <div class="nav-wrap">
            <nav class="nav">
              <a href="/contacts" id="nav-contacts">{translations.ru.navContacts}</a>
            </nav>

            <div class="lang-switcher">
              <button class="lang-btn active" data-lang="ru" type="button" onclick="setLang('ru')">RU</button>
              <button class="lang-btn" data-lang="en" type="button" onclick="setLang('en')">EN</button>
              <button class="lang-btn" data-lang="fr" type="button" onclick="setLang('fr')">FR</button>
            </div>
          </div>
        </div>
      </header>

      <section class="hero">
        <div class="hero-inner">
          <h1 id="hero-title">{translations.ru.heroTitle}</h1>
          <p id="hero-subtitle">{translations.ru.heroSubtitle}</p>

          <div class="hero-buttons">
            <a class="hero-btn" href="/about" id="hero-btn-about">{translations.ru.heroBtnAbout}</a>
            <a class="hero-btn" href="/biogeo" id="hero-btn-biogeo">{translations.ru.heroBtnBiogeo}</a>
            <a class="hero-btn" href="/humanitarian" id="hero-btn-humanitarian">{translations.ru.heroBtnHumanitarian}</a>
          </div>
        </div>
      </section>

      <main class="content">
        <div class="section-head" id="skills">
          <h2 id="section-title">{translations.ru.sectionTitle}</h2>
          <p id="section-subtitle">{translations.ru.sectionSubtitle}</p>
        </div>

        <div class="cards">
          {gisBlocks.map((item, index) => (
            <a class="project-card" href={item.link} style={`background-image: url('${item.image}')`}>
              <div class="project-overlay"></div>
              <div class="project-content">
                <h3 id={`card-city-${index}`}>{translations.ru.cards[index].city}</h3>
                <div class="project-theme" id={`card-theme-${index}`}>
                  {translations.ru.cards[index].theme}
                </div>
                <div class="project-line"></div>
                <div class="project-desc" id={`card-desc-${index}`}>
                  {translations.ru.cards[index].desc}
                </div>
              </div>
            </a>
          ))}
        </div>

        <div class="cta-senegal-wrap">
          <div class="cta-senegal-row">
            <a
              class="hero-btn cta-senegal-btn"
              href="https://senegal-gis-data.vercel.app/en/"
              id="hero-btn-senegal"
              target="_blank"
              rel="noopener noreferrer"
            >
              {translations.ru.heroBtnSenegalGis}
            </a>

            <a
              class="hero-btn cta-senegal-btn"
              href="https://notcoin-strategy.vercel.app/"
              id="hero-btn-notcoin"
              target="_blank"
              rel="noopener noreferrer"
            >
              {translations.ru.heroBtnNotcoin}
            </a>
          </div>
        </div>
      </main>
    </div>

    <script define:vars={{ translations }}>
      const i18n = translations;
      const LANG_KEY = "lang";

      /** [elementId, key on translation object] */
      const textFields = [
        ["brand", "brand"],
        ["nav-contacts", "navContacts"],
        ["hero-title", "heroTitle"],
        ["hero-subtitle", "heroSubtitle"],
        ["hero-btn-about", "heroBtnAbout"],
        ["hero-btn-biogeo", "heroBtnBiogeo"],
        ["hero-btn-sahel", "heroBtnSahel"],
        ["hero-btn-humanitarian", "heroBtnHumanitarian"],
        ["hero-btn-senegal", "heroBtnSenegalGis"],
        ["hero-btn-notcoin", "heroBtnNotcoin"],
        ["section-title", "sectionTitle"],
        ["section-subtitle", "sectionSubtitle"]
      ];

      function notifyLanguageChanged(lang) {
        window.dispatchEvent(new CustomEvent("languageChanged", { detail: { lang } }));
      }

      window.setLang = function (lang) {
        const t = i18n[lang];
        if (!t) return;

        document.documentElement.lang = lang;
        document.title = t.brand;

        for (const [id, key] of textFields) {
          const el = document.getElementById(id);
          if (el) el.textContent = t[key];
        }

        t.cards.forEach((card, index) => {
          const city = document.getElementById(`card-city-${index}`);
          const theme = document.getElementById(`card-theme-${index}`);
          const desc = document.getElementById(`card-desc-${index}`);
          if (city) city.textContent = card.city;
          if (theme) theme.textContent = card.theme;
          if (desc) desc.textContent = card.desc;
        });

        document.querySelectorAll(".lang-btn").forEach((btn) => {
          btn.classList.toggle("active", btn.dataset.lang === lang);
        });

        localStorage.setItem(LANG_KEY, lang);
        notifyLanguageChanged(lang);
      };

      window.setLang(localStorage.getItem(LANG_KEY) || "ru");
    </script>
  </body>
</html>
