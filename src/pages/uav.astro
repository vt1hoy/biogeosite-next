---
/**
 * UAV case page — section order: intro → maps → PDFs → code → workflow → pipeline.
 * Maps / PDFs / workflow / pipeline blocks are present for layout parity; this case ships no extra assets yet (empty arrays).
 */
import SiteLayout2 from "../layouts/SiteLayout2.astro";

const pageTranslations = {
  ru: { title: "БПЛА — MAVLink", subtitle: "Подключение к SITL и работа через MAVLink" },
  en: { title: "UAV — MAVLink", subtitle: "SITL connection and MAVLink interaction" },
  fr: { title: "UAV — MAVLink", subtitle: "Connexion SITL et MAVLink" }
};

const images: { src: string }[] = [];
const pdfs: { file: string }[] = [];
const pipelineScripts: { name: string; file: string }[] = [];

const codeFetchTargets = [
  { id: "code1", path: "/assets/uav/code/mavlink_connect.py" },
  { id: "code2", path: "/assets/uav/code/sitl_setup.txt" }
];

const translations = {
  ru: {
    caseLabel: "Кейс",
    caseIntro: "Подключение к SITL, отправка команд и попытка получить телеметрию.",
    caseResultsTitle: "Что сделано",
    caseResults: [
      "Поднят SITL",
      "Подключение MAVLink",
      "Команды отправлены",
      "Попытка навигации",
      "Чтение телеметрии"
    ],
    maps: "Карты",
    pdf: "PDF",
    workflow: "Workflow",
    python: "Python / MAVLink",
    pipeline: "Full pipeline",
    pipelineSubtitle: "",
    pdfOpen: "Открыть PDF",
    fileOpen: "Открыть файл",
    scriptOpen: "Скачать / открыть",
    copy: "Копировать",
    copied: "Скопировано",
    imageTitles: [] as string[],
    pdfTitles: [] as string[],
    workflowItems: [] as { title: string; steps: string[] }[],
    codeTitle1: "MAVLink — mission control",
    codeDesc1: "Подключение и команды",
    codeTitle2: "SITL / WSL setup",
    codeDesc2: "Установка SITL",
    codeLoadError: "Ошибка загрузки кода"
  },

  en: {
    caseLabel: "Case",
    caseIntro: "SITL connection, command sending and telemetry reading.",
    caseResultsTitle: "What was done",
    caseResults: [
      "SITL deployed",
      "MAVLink connected",
      "Commands sent",
      "Waypoint attempt",
      "Telemetry read"
    ],
    maps: "Maps",
    pdf: "PDF",
    workflow: "Workflow",
    python: "Python / MAVLink",
    pipeline: "Full pipeline",
    pipelineSubtitle: "",
    pdfOpen: "Open PDF",
    fileOpen: "Open file",
    scriptOpen: "Download / open",
    copy: "Copy",
    copied: "Copied",
    imageTitles: [] as string[],
    pdfTitles: [] as string[],
    workflowItems: [] as { title: string; steps: string[] }[],
    codeTitle1: "MAVLink — mission control",
    codeDesc1: "Connection and commands",
    codeTitle2: "SITL / WSL setup",
    codeDesc2: "SITL setup",
    codeLoadError: "Code loading error"
  },

  fr: {
    caseLabel: "Cas",
    caseIntro: "Connexion SITL, commandes et télémétrie.",
    caseResultsTitle: "Résultats",
    caseResults: [
      "SITL lancé",
      "Connexion MAVLink",
      "Commandes envoyées",
      "Navigation test",
      "Télémétrie"
    ],
    maps: "Cartes",
    pdf: "PDF",
    workflow: "Workflow",
    python: "Python / MAVLink",
    pipeline: "Full pipeline",
    pipelineSubtitle: "",
    pdfOpen: "Ouvrir le PDF",
    fileOpen: "Ouvrir le fichier",
    scriptOpen: "Télécharger / ouvrir",
    copy: "Copier",
    copied: "Copié",
    imageTitles: [] as string[],
    pdfTitles: [] as string[],
    workflowItems: [] as { title: string; steps: string[] }[],
    codeTitle1: "MAVLink — mission control",
    codeDesc1: "Connexion et commandes",
    codeTitle2: "SITL / WSL setup",
    codeDesc2: "Installation SITL",
    codeLoadError: "Erreur de chargement du code"
  }
};
---

<SiteLayout2 pageTranslations={pageTranslations}>
  <style>
    .block {
      --case-border: #d9e1ea;
      --case-surface: rgba(255, 255, 255, 0.96);
      --case-surface-muted: #fbfdff;
      --case-heading: #1d3d67;
      --case-subheading: #284a73;
      --case-text: #425b78;
      --case-muted: #5d6f86;
      --case-link: #174b87;

      background: var(--case-surface);
      padding: 26px 24px;
      border-radius: 18px;
      margin-bottom: 24px;
      border: 1px solid var(--case-border);
      box-shadow: 0 8px 20px rgba(40, 60, 90, 0.05);
    }

    .block h2 {
      margin: 0 0 18px;
      padding-bottom: 10px;
      border-bottom: 1px solid #e8edf3;
      color: var(--case-heading);
      font-size: 28px;
      letter-spacing: -0.02em;
    }

    .intro-text {
      color: var(--case-text);
      line-height: 1.72;
      font-size: 15px;
      margin-bottom: 18px;
      max-width: 980px;
    }

    .findings-title {
      color: var(--case-subheading);
      margin: 22px 0 12px;
      font-size: 18px;
    }

    .findings-list {
      margin: 0;
      padding-left: 1.25rem;
      color: var(--case-text);
      line-height: 1.8;
      list-style-type: disc;
    }

    .findings-list li {
      margin-bottom: 4px;
    }

    .image-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    .image-card {
      background: #fff;
      border: 1px solid #dde5ed;
      border-radius: 14px;
      overflow: hidden;
    }

    .image-card img {
      width: 100%;
      display: block;
      aspect-ratio: 16 / 10;
      object-fit: cover;
    }

    .image-caption {
      padding: 14px 16px;
      font-size: 14px;
      color: var(--case-muted);
    }

    .image-caption a {
      color: var(--case-link);
      font-weight: 600;
    }

    .pdf-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .pdf-card {
      background: var(--case-surface-muted);
      border: 1px solid #e1e8f0;
      border-radius: 14px;
      padding: 18px 20px;
    }

    .pdf-card h3 {
      margin: 0 0 12px;
      color: var(--case-subheading);
      font-size: 18px;
    }

    .pdf-card a {
      color: var(--case-link);
      font-weight: 600;
      font-size: 14px;
    }

    .workflow-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    .workflow-item {
      background: var(--case-surface-muted);
      border: 1px solid #e1e8f0;
      border-radius: 14px;
      padding: 18px 20px;
    }

    .workflow-item h3 {
      margin: 0 0 14px;
      color: var(--case-subheading);
      font-size: 18px;
      line-height: 1.35;
    }

    .workflow-item ul {
      margin: 0;
      padding-left: 1.25rem;
      line-height: 1.75;
      color: var(--case-text);
      list-style-type: disc;
    }

    .workflow-item li {
      margin-bottom: 6px;
    }

    .pipeline-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
    }

    .pipeline-card {
      display: flex;
      flex-direction: column;
      gap: 12px;
      background: var(--case-surface-muted);
      border: 1px solid #e1e8f0;
      border-radius: 14px;
      padding: 18px 20px;
    }

    .script-name {
      margin: 0;
      font-size: 16px;
      font-weight: 700;
      color: var(--case-heading);
      font-family: Consolas, monospace;
      line-height: 1.45;
    }

    .pipeline-card a {
      color: var(--case-link);
      font-weight: 600;
      font-size: 14px;
    }

    .code-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 22px;
    }

    .code-card {
      background: var(--case-surface-muted);
      border: 1px solid #e1e8f0;
      border-radius: 14px;
      padding: 18px 20px;
    }

    .code-card h3 {
      margin: 0 0 12px;
      color: var(--case-subheading);
    }

    .code-description {
      margin-bottom: 14px;
      color: #5b6d85;
      font-size: 14px;
      line-height: 1.6;
    }

    .code-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
      flex-wrap: wrap;
    }

    .code-top a {
      color: var(--case-link);
      font-weight: 600;
      font-size: 14px;
    }

    .btn {
      background: var(--case-link);
      color: white;
      border: none;
      padding: 8px 14px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 14px;
    }

    .btn:hover {
      opacity: 0.92;
    }

    .code-block {
      background: #0f1722;
      color: #d9e7ff;
      padding: 16px;
      border-radius: 12px;
      font-family: Consolas, monospace;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
      word-break: break-word;
      overflow-x: auto;
      overflow-y: auto;
      line-height: 1.55;
      max-height: 420px;
      font-size: 13px;
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.04);
    }

    .code-card,
    .code-block,
    .pipeline-card,
    .workflow-item,
    .pdf-card,
    .image-card {
      min-width: 0;
    }

    .code-card h3,
    .code-description,
    .code-top a,
    .script-name,
    .image-caption a,
    .pdf-card h3,
    .workflow-item h3,
    .block p,
    .block li {
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    @media (max-width: 1100px) {
      .pipeline-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 900px) {
      .image-grid,
      .workflow-grid,
      .pipeline-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      .block {
        padding: 18px 16px;
        border-radius: 14px;
      }

      .block h2 {
        font-size: 22px;
        line-height: 1.2;
      }

      .block h3,
      .code-card h3,
      .workflow-item h3,
      .pdf-card h3 {
        font-size: 17px;
        line-height: 1.3;
      }

      .code-card,
      .pipeline-card,
      .workflow-item,
      .pdf-card {
        padding: 16px;
        border-radius: 12px;
      }

      .code-top {
        align-items: stretch;
      }

      .btn {
        width: 100%;
      }

      .code-block {
        font-size: 11px;
        padding: 12px;
      }
    }
  </style>

  <!-- 1. Description / context -->
  <div class="block">
    <h2 id="intro-heading">{translations.ru.caseLabel}</h2>
    <div class="intro-text" id="intro-text">{translations.ru.caseIntro}</div>

    <h3 class="findings-title" id="findings-heading">{translations.ru.caseResultsTitle}</h3>

    <ul class="findings-list" id="findings-list">
      {translations.ru.caseResults.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </div>

  <!-- 2. Maps / visuals -->
  <div class="block">
    <h2 id="maps-heading">{translations.ru.maps}</h2>
    <div class="image-grid">
      {images.map((item, index) => (
        <div class="image-card">
          <a href={item.src} target="_blank" rel="noopener noreferrer">
            <img src={item.src} alt={`uav-image-${index + 1}`} />
          </a>
          <div class="image-caption">
            <a href={item.src} target="_blank" rel="noopener noreferrer" id={`image-title-${index}`}>
              {translations.ru.imageTitles[index]}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- 3. PDFs -->
  <div class="block">
    <h2 id="pdf-heading">{translations.ru.pdf}</h2>
    <div class="pdf-grid">
      {pdfs.map((pdf, index) => (
        <div class="pdf-card">
          <h3 id={`pdf-title-${index}`}>{translations.ru.pdfTitles[index]}</h3>
          <a href={pdf.file} target="_blank" rel="noopener noreferrer" class="pdf-open">
            {translations.ru.pdfOpen}
          </a>
        </div>
      ))}
    </div>
  </div>

  <!-- 4. Code blocks -->
  <div class="block">
    <h2 id="python-heading">{translations.ru.python}</h2>

    <div class="code-grid">
      <div class="code-card">
        <h3 id="code-title-1">{translations.ru.codeTitle1}</h3>
        <div class="code-description" id="code-desc-1">{translations.ru.codeDesc1}</div>

        <div class="code-top">
          <a
            href="/assets/uav/code/mavlink_connect.py"
            target="_blank"
            rel="noopener noreferrer"
            class="code-open"
          >
            {translations.ru.fileOpen}
          </a>
          <button type="button" class="btn copy-btn" onclick="copyCode('code1', this)">
            {translations.ru.copy}
          </button>
        </div>

        <pre class="code-block" id="code1">Загрузка...</pre>
      </div>

      <div class="code-card">
        <h3 id="code-title-2">{translations.ru.codeTitle2}</h3>
        <div class="code-description" id="code-desc-2">{translations.ru.codeDesc2}</div>

        <div class="code-top">
          <a
            href="/assets/uav/code/sitl_setup.txt"
            target="_blank"
            rel="noopener noreferrer"
            class="code-open"
          >
            {translations.ru.fileOpen}
          </a>
          <button type="button" class="btn copy-btn" onclick="copyCode('code2', this)">
            {translations.ru.copy}
          </button>
        </div>

        <pre class="code-block" id="code2">Загрузка...</pre>
      </div>
    </div>
  </div>

  <!-- 5. Workflow -->
  <div class="block">
    <h2 id="workflow-heading">{translations.ru.workflow}</h2>
    <div class="workflow-grid">
      {translations.ru.workflowItems.map((wf, wfIndex) => (
        <div class="workflow-item">
          <h3 id={`workflow-title-${wfIndex}`}>{wf.title}</h3>
          <ul id={`workflow-steps-${wfIndex}`}>
            {wf.steps.map((step) => (
              <li>{step}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- 6. Full pipeline -->
  <div class="block">
    <h2 id="pipeline-heading">{translations.ru.pipeline}</h2>
    <div class="intro-text" id="pipeline-intro">{translations.ru.pipelineSubtitle}</div>

    <div class="pipeline-grid">
      {pipelineScripts.map((script) => (
        <div class="pipeline-card">
          <p class="script-name">{script.name}</p>
          <a href={script.file} target="_blank" rel="noopener noreferrer" class="script-open">
            {translations.ru.scriptOpen}
          </a>
        </div>
      ))}
    </div>
  </div>

  <script define:vars={{ translations, codeFetchTargets }}>
    const i18n = translations;
    const LANG_KEY = "lang";

    const staticTextFields = [
      ["intro-heading", "caseLabel"],
      ["intro-text", "caseIntro"],
      ["findings-heading", "caseResultsTitle"],
      ["maps-heading", "maps"],
      ["pdf-heading", "pdf"],
      ["workflow-heading", "workflow"],
      ["python-heading", "python"],
      ["pipeline-heading", "pipeline"],
      ["pipeline-intro", "pipelineSubtitle"],
      ["code-title-1", "codeTitle1"],
      ["code-title-2", "codeTitle2"],
      ["code-desc-1", "codeDesc1"],
      ["code-desc-2", "codeDesc2"]
    ];

    function setText(id, text) {
      const el = document.getElementById(id);
      if (el) el.textContent = text;
    }

    function fillListElement(id, items) {
      const root = document.getElementById(id);
      if (!root) return;
      root.replaceChildren(
        ...items.map((item) => {
          const li = document.createElement("li");
          li.textContent = item;
          return li;
        })
      );
    }

    function applyIndexedTitles(prefix, titles) {
      titles.forEach((title, index) => {
        setText(`${prefix}-${index}`, title);
      });
    }

    function applyUavCopy(lang) {
      const t = i18n[lang];
      if (!t) return;

      for (const [id, key] of staticTextFields) {
        setText(id, t[key]);
      }

      fillListElement("findings-list", t.caseResults);

      t.workflowItems.forEach((wf, wfIndex) => {
        setText(`workflow-title-${wfIndex}`, wf.title);
        fillListElement(`workflow-steps-${wfIndex}`, wf.steps);
      });

      applyIndexedTitles("image-title", t.imageTitles);
      applyIndexedTitles("pdf-title", t.pdfTitles);

      document.querySelectorAll(".pdf-open").forEach((el) => {
        el.textContent = t.pdfOpen;
      });
      document.querySelectorAll(".code-open").forEach((el) => {
        el.textContent = t.fileOpen;
      });
      document.querySelectorAll(".script-open").forEach((el) => {
        el.textContent = t.scriptOpen;
      });
      document.querySelectorAll(".copy-btn").forEach((btn) => {
        btn.textContent = t.copy;
        btn.dataset.copyLabel = t.copy;
        btn.dataset.copiedLabel = t.copied;
      });
    }

    async function loadCode(id, path) {
      const el = document.getElementById(id);
      if (!el) return;
      try {
        const res = await fetch(path);
        if (!res.ok) throw new Error("fetch failed");
        el.textContent = await res.text();
      } catch {
        const lang = localStorage.getItem(LANG_KEY) || "ru";
        el.textContent = i18n[lang]?.codeLoadError ?? i18n.ru.codeLoadError;
      }
    }

    window.copyCode = function (id, btn) {
      const el = document.getElementById(id);
      if (!el) return;
      const text = el.textContent;
      navigator.clipboard.writeText(text);

      const copiedLabel = btn.dataset.copiedLabel || "Скопировано";
      const copyLabel = btn.dataset.copyLabel || "Копировать";

      btn.textContent = copiedLabel;
      setTimeout(() => {
        btn.textContent = copyLabel;
      }, 1200);
    };

    function initUavPage() {
      applyUavCopy(localStorage.getItem(LANG_KEY) || "ru");

      window.addEventListener("languageChanged", (event) => {
        applyUavCopy(event.detail.lang);
      });

      for (const { id, path } of codeFetchTargets) {
        loadCode(id, path);
      }
    }

    initUavPage();
  </script>
</SiteLayout2>
