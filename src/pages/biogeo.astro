---

<SiteLayout2 pageTranslations={pageTranslations}>
  <style>
    .biogeo-page {
      --bio-border: #d9e1ea;
      --bio-surface: rgba(255, 255, 255, 0.96);
      --bio-muted: #fbfdff;
      --bio-heading: #1d3d67;
      --bio-subheading: #284a73;
      --bio-text: #425b78;
      --bio-caption: #5d6f86;
      --bio-link: #174b87;
      --bio-line: #e8edf3;
    }

    .biogeo-section {
      margin-top: 28px;
    }

    .biogeo-section:first-of-type {
      margin-top: 0;
    }

    .top-grid {
      display: grid;
      grid-template-columns: 1.15fr 1fr;
      gap: 22px;
    }

    .card {
      background: var(--bio-surface);
      border: 1px solid var(--bio-border);
      border-radius: 18px;
      padding: 22px 24px;
      box-shadow: 0 8px 20px rgba(40, 60, 90, 0.05);
    }

    .card h2 {
      margin: 0 0 16px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--bio-line);
      color: var(--bio-heading);
      font-size: 24px;
      letter-spacing: -0.02em;
      line-height: 1.2;
    }

    .card p,
    .card li {
      color: var(--bio-text);
      line-height: 1.75;
      font-size: 15px;
    }

    .list-block {
      margin: 0;
      padding-left: 1.25rem;
      list-style-type: disc;
    }

    .list-block li {
      margin-bottom: 8px;
    }

    .metrics-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
    }

    .metric-box {
      background: var(--bio-muted);
      border: 1px solid #e1e8f0;
      border-radius: 14px;
      padding: 16px 18px;
    }

    .metric-label {
      margin: 0 0 8px;
      font-size: 12px;
      color: var(--bio-caption);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      font-weight: 600;
    }

    .metric-value {
      margin: 0;
      font-size: 20px;
      font-weight: 800;
      color: var(--bio-heading);
      line-height: 1.2;
    }

    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 22px;
    }

    .links-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }

    .link-card {
      background: var(--bio-muted);
      border: 1px solid #e1e8f0;
      border-radius: 14px;
      padding: 18px 20px;
    }

    .link-card h3 {
      margin: 0 0 12px;
      color: var(--bio-subheading);
      font-size: 17px;
      line-height: 1.3;
    }

    .link-card a {
      color: var(--bio-link);
      font-weight: 600;
      text-decoration: none;
      font-size: 14px;
    }

    .card,
    .link-card {
      min-width: 0;
    }

    .card h2,
    .card p,
    .card li,
    .link-card h3 {
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    @media (max-width: 980px) {
      .top-grid,
      .two-col,
      .links-grid,
      .metrics-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      .top-grid,
      .two-col,
      .links-grid {
        gap: 18px;
      }

      .card {
        padding: 18px 16px;
        border-radius: 14px;
      }

      .card h2 {
        font-size: 21px;
      }

      .link-card {
        padding: 16px;
        border-radius: 12px;
      }

      .metrics-grid {
        gap: 12px;
      }
    }
  </style>

  <div class="biogeo-page">
    <!-- Idea + live metrics -->
    <section class="biogeo-section">
      <div class="top-grid">
        <div class="card">
          <h2 id="idea-title">{content.ru.ideaTitle}</h2>
          <ul class="list-block" id="idea-list">
            {content.ru.idea.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>

        <div class="card">
          <h2 id="metrics-title">{content.ru.metricsTitle}</h2>
          <div class="metrics-grid">
            {content.ru.metrics.map((item, index) => (
              <div class="metric-box">
                <p class="metric-label" id={`metric-label-${index}`}>
                  {item.label}
                </p>
                <p class="metric-value" id={`metric-value-${index}`}>
                  {item.value}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Tokenomics + roadmap -->
    <section class="biogeo-section">
      <div class="two-col">
        <div class="card">
          <h2 id="tokenomics-title">{content.ru.tokenomicsTitle}</h2>
          <ul class="list-block" id="tokenomics-list">
            {content.ru.tokenomics.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>

        <div class="card">
          <h2 id="roadmap-title">{content.ru.roadmapTitle}</h2>
          <ul class="list-block" id="roadmap-list">
            {content.ru.roadmap.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- On-chain links -->
    <section class="biogeo-section">
      <div class="card">
        <h2 id="links-title">{content.ru.linksTitle}</h2>
        <div class="links-grid">
          {links.map((item, index) => (
            <div class="link-card">
              <h3>{item.label}</h3>
              <a href={item.href} target="_blank" rel="noopener noreferrer" id={`open-link-${index}`}>
                {content.ru.openLink}
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Notes -->
    <section class="biogeo-section">
      <div class="card">
        <h2 id="notes-title">{content.ru.notesTitle}</h2>
        <ul class="list-block" id="notes-list">
          {content.ru.notes.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </section>
  </div>

  <script define:vars={{ content }}>
    const i18n = content;
    const LANG_KEY = "lang";

    function setText(id, text) {
      const el = document.getElementById(id);
      if (el) el.textContent = text;
    }

    function fillListElement(id, items) {
      const root = document.getElementById(id);
      if (!root) return;
      root.replaceChildren(
        ...items.map((text) => {
          const li = document.createElement("li");
          li.textContent = text;
          return li;
        })
      );
    }

    function applyBiogeoCopy(lang) {
      const t = i18n[lang];
      if (!t) return;

      setText("idea-title", t.ideaTitle);
      setText("metrics-title", t.metricsTitle);
      setText("tokenomics-title", t.tokenomicsTitle);
      setText("roadmap-title", t.roadmapTitle);
      setText("links-title", t.linksTitle);
      setText("notes-title", t.notesTitle);

      fillListElement("idea-list", t.idea);
      fillListElement("tokenomics-list", t.tokenomics);
      fillListElement("roadmap-list", t.roadmap);
      fillListElement("notes-list", t.notes);

      t.metrics.forEach((item, index) => {
        setText(`metric-label-${index}`, item.label);
        setText(`metric-value-${index}`, item.value);
      });

      document.querySelectorAll("[id^='open-link-']").forEach((el) => {
        el.textContent = t.openLink;
      });
    }

    function initBiogeoPage() {
      applyBiogeoCopy(localStorage.getItem(LANG_KEY) || "ru");

      window.addEventListener("languageChanged", (event) => {
        applyBiogeoCopy(event.detail.lang);
      });
    }

    initBiogeoPage();
  </script>
</SiteLayout2>
