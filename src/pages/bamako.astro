        ]
      }
    ],
    codeTitle1: "SQL — классификация по расстоянию до Бамако",
    codeTitle2: "SQL — анализ локальной плотности (100 км)",
    codeDesc1:
      "Рассчитывает расстояние от каждого месторождения до Бамако и классифицирует его по уровням доступности (high / medium / low)",
    codeDesc2:
      "Определяет количество соседних месторождений в радиусе 100 км для оценки локальной плотности",
    codeLoadError: "Ошибка загрузки кода"
  },

  en: {
    caseLabel: "Case",
    caseIntro:
      "This case study presents a pilot spatial analysis of mineral occurrences in Mali using USGS MRDS data. The analysis includes distance-based classification from Bamako and local density assessment (100 km radius) to identify spatial patterns and resource concentration zones.",
    caseResultsTitle: "Key results",
    caseResults: [
      "A strong cluster of diatomite deposits is identified in northern Mali, with high density (up to 9 neighboring occurrences within 100 km).",
      "The southern region shows a more dispersed polymetallic structure (gold, lithium, manganese).",
      "The western region (Kayes) forms a distinct zone with gold, aluminum, and diamond occurrences.",
      "Eastern deposits (phosphates and manganese) appear as isolated, low-density occurrences.",
      "The overall pattern highlights a contrast between clustered and dispersed resource distributions."
    ],
    maps: "Maps",
    pdf: "PDF",
    workflow: "Workflow",
    python: "SQL / PostGIS",
    pipeline: "Full pipeline",
    pipelineSubtitle: "Complete script sequence used in this case",
    pdfOpen: "Open PDF",
    fileOpen: "Open file",
    scriptOpen: "Download / open",
    copy: "Copy",
    copied: "Copied",
    imageTitles: ["Commodity type and distance from Bamako", "Local clustering of mineral occurrences"],
    pdfTitles: ["GIS Analysis Brief"],
    workflowItems: [
      {
        title: "Workflow 1 — data preparation",
        steps: [
          "Import MRDS data into PostGIS (shp2pgsql)",
