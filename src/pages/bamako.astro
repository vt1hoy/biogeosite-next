---
/**
 * Bamako GIS case page — section order: intro → maps → PDFs → code → workflow → pipeline.
 */
import SiteLayout2 from "../layouts/SiteLayout2.astro";

const pageTranslations = {
  ru: {
    title: "Бамако - минеральные ресурсы",
    subtitle:
      "Пилотный GIS-кейс по пространственному анализу месторождений в Мали на основе данных USGS MRDS: типы ресурсов, расстояние до Бамако и локальная кластеризация (100 км радиус)."
  },
  en: {
    title: "Bamako — mineral resources",
    subtitle:
      "Pilot GIS case study on spatial analysis of mineral occurrences in Mali using USGS MRDS data: commodity types, distance from Bamako, and local clustering (100 km radius)."
  },
  fr: {
    title: "Bamako — ressources minérales",
    subtitle:
      "Étude de cas SIG pilote sur l’analyse spatiale des occurrences minérales au Mali à partir des données USGS MRDS : types de ressources, distance à Bamako et clustering local (rayon de 100 km)."
  }
};

const images = [
  { src: "/assets/bamako/images/commodity_type_distance.png" },
  { src: "/assets/bamako/images/local_clustering.png" }
];

const pdfs = [{ file: "/assets/bamako/pdf/brief_bamako.pdf" }];

const pipelineScripts = [
  { name: "1. distance.sql", file: "/assets/bamako/code/distance.sql" },
  { name: "2. density.sql", file: "/assets/bamako/code/density.sql" },
  { name: "3. distance_class.sql", file: "/assets/bamako/code/distance_class.sql" },
  { name: "4. local_neighborhood.sql", file: "/assets/bamako/code/local_neighborhood.sql" }
];

const codeFetchTargets = [
  { id: "code1", path: "/assets/bamako/code/distance_class.sql" },
  { id: "code2", path: "/assets/bamako/code/local_neighborhood.sql" }
];

const translations = {
  ru: {
    caseLabel: "Кейс",
    caseIntro:
      "Этот кейс представляет пилотный spatial analysis распределения месторождений в Мали на основе данных USGS MRDS. Анализ включает классификацию по расстоянию до Бамако и оценку локальной плотности (100 км радиус), чтобы выявить пространственные паттерны и зоны концентрации ресурсов.",
    caseResultsTitle: "Что получилось",
    caseResults: [
      "Выявлен выраженный кластер диатомитовых месторождений на севере Мали с высокой плотностью (до 9 соседей в радиусе 100 км).",
      "Южная часть характеризуется более разреженной полиметаллической зоной (золото, литий, марганец).",
      "Западный регион (Kayes) формирует отдельную зону с золотом, алюминием и алмазами.",
      "Восточные месторождения (фосфаты и марганец) представлены изолированными точками с низкой плотностью.",
      "Итоговая структура показывает контраст между кластеризованными и дисперсными типами ресурсов."
    ],
    maps: "Карты",
    pdf: "PDF",
    workflow: "Workflow",
    python: "SQL / PostGIS",
    pipeline: "Full pipeline",
    pipelineSubtitle: "Полная последовательность скриптов по кейсу",
    pdfOpen: "Открыть PDF",
    fileOpen: "Открыть файл",
    scriptOpen: "Скачать / открыть",
    copy: "Копировать",
    copied: "Скопировано",
    imageTitles: ["Типы ресурсов и расстояние до Бамако", "Локальная плотность месторождений"],
    pdfTitles: ["Аналитическая записка"],
    workflowItems: [
      {
        title: "Workflow 1 — подготовка данных",
        steps: [
          "Импорт данных MRDS в PostGIS (shp2pgsql)",
