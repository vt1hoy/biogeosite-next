---
/**
 * Inner pages: shared chrome + slot for page content.
 * Pass pageTranslations: { ru: { title, subtitle }, en: {...}, fr: {...} } }
 *
 * Nav mode is derived from URL: case pages show GIS city links; /about, /biogeo, /humanitarian, /contacts show app links.
 */
const { pageTranslations } = Astro.props;

function normalizePathname(pathname: string) {
  const base = (import.meta.env.BASE_URL || "/").replace(/\/+$/, "") || "";
  let p = pathname.split("?")[0] || "/";
  if (base !== "/" && base && p.startsWith(base)) {
    p = p.slice(base.length) || "/";
  }
  p = p.replace(/\/+$/, "") || "/";
  return p;
}

const currentPath = normalizePathname(Astro.url.pathname);
const CONTENT_NAV_PATHS = new Set(["/about", "/biogeo", "/humanitarian", "/contacts"]);
const isAppNav = CONTENT_NAV_PATHS.has(currentPath);

const navTranslations = {
  ru: {
    home: "Главная",
    dakar: "Дакар",
    bamako: "Бамако",
    ouaga: "Уагадугу",
    niamey: "Ниамей",
    uav: "БПЛА",
    back: "← назад"
  },
  en: {
    home: "Home",
    dakar: "Dakar",
    bamako: "Bamako",
    ouaga: "Ouagadougou",
    niamey: "Niamey",
    uav: "UAV",
    back: "← back"
  },
  fr: {
    home: "Accueil",
    dakar: "Dakar",
    bamako: "Bamako",
    ouaga: "Ouagadougou",
    niamey: "Niamey",
    uav: "UAV",
    back: "← retour"
  }
};

const appNavTranslations = {
  ru: {
    home: "Главная",
    about: "Обо мне",
    biogeo: "BIOGEO",
    humanitarian: "Гуманитарные миссии",
    back: "← назад"
  },
  en: {
    home: "Home",
    about: "About",
    biogeo: "BIOGEO",
    humanitarian: "Humanitarian missions",
    back: "← back"
  },
  fr: {
    home: "Accueil",
    about: "À propos",
    biogeo: "BIOGEO",
    humanitarian: "Missions humanitaires",
    back: "← retour"
  }
};

const navLabelsInitial = isAppNav ? appNavTranslations.ru : navTranslations.ru;
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTranslations.ru.title}</title>

    <style>
      :root {
        --card: rgba(255, 255, 255, 0.96);
        --text: #17365d;
        --muted: #5d6f86;
        --line: #d8dde5;
        --blue: #174b87;
        --shadow: 0 18px 45px rgba(31, 51, 81, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Inter, Arial, sans-serif;
        background: linear-gradient(180deg, #edf1f5 0%, #e7edf3 100%);
        color: var(--text);
      }

      a {
        text-decoration: none;
        color: inherit;
      }

      .shell {
        width: min(1300px, calc(100% - 40px));
        margin: 28px auto;
        background: rgba(255, 255, 255, 0.82);
        border: 1px solid rgba(210, 220, 230, 0.9);
        border-radius: 28px;
        box-shadow: var(--shadow);
        overflow: hidden;
      }

      .header {
        background: rgba(255, 255, 255, 0.9);
        border-bottom: 1px solid var(--line);
      }

      .header-inner {
        width: min(1240px, calc(100% - 48px));
        margin: 0 auto;
        min-height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
      }

      .brand {
        font-size: 24px;
        font-weight: 800;
        color: var(--blue);
        letter-spacing: -0.02em;
        text-transform: uppercase;
      }

      .nav-wrap {
        display: flex;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
      }

      .nav {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
      }

      .nav a {
        font-size: 15px;
        color: #50627b;
        font-weight: 600;
      }

      .lang {
        display: flex;
        gap: 6px;
      }

      .lang button {
        padding: 6px 10px;
        border-radius: 8px;
        border: 1px solid #ccd6e2;
        background: #eef2f6;
        cursor: pointer;
        font-size: 12px;
        font-weight: 700;
        color: var(--blue);
      }

      .lang button.active {
        background: var(--blue);
        color: white;
      }

      .content {
        width: min(1240px, calc(100% - 48px));
        margin: 0 auto;
        padding: 32px 12px 40px;
      }

      .hero-text {
        padding-left: 24px;
        margin-bottom: 24px;
      }

      .back-link {
        display: block;
        margin-bottom: 18px;
        color: var(--blue);
        font-weight: 600;
        font-size: 14px;
      }

      h1 {
        margin: 8px 0 0;
        font-size: clamp(34px, 4vw, 52px);
        letter-spacing: -0.03em;
      }

      .subtitle {
        margin-top: 12px;
        font-size: 17px;
        color: var(--muted);
        max-width: 840px;
        line-height: 1.65;
      }

      @media (max-width: 980px) {
        .header-inner {
          flex-direction: column;
          align-items: flex-start;
          gap: 12px;
          padding: 12px 0;
        }

        .nav {
          gap: 14px;
        }

        .hero-text {
          padding-left: 10px;
        }
      }
    </style>
  </head>

  <body>
    <div class="shell">
      <header class="header">
        <div class="header-inner">
          <div class="brand">BIOGEO</div>

          <div class="nav-wrap">
            <nav class="nav">
              <a href="/" id="nav-home">{navLabelsInitial.home}</a>
              {isAppNav ? (
                <>
                  <a href="/about" id="nav-about">{navLabelsInitial.about}</a>
                  <a href="/biogeo" id="nav-biogeo">{navLabelsInitial.biogeo}</a>
                  <a href="/humanitarian" id="nav-humanitarian">{navLabelsInitial.humanitarian}</a>
                </>
              ) : (
                <>
                  <a href="/dakar" id="nav-dakar">{navLabelsInitial.dakar}</a>
                  <a href="/bamako" id="nav-bamako">{navLabelsInitial.bamako}</a>
                  <a href="/ouagadougou" id="nav-ouaga">{navLabelsInitial.ouaga}</a>
                  <a href="/niamey" id="nav-niamey">{navLabelsInitial.niamey}</a>
                  <a href="/uav" id="nav-uav">{navLabelsInitial.uav}</a>
                </>
              )}
            </nav>

            <div class="lang">
              <button type="button" onclick="setLang('ru')" data-lang="ru">RU</button>
              <button type="button" onclick="setLang('en')" data-lang="en">EN</button>
              <button type="button" onclick="setLang('fr')" data-lang="fr">FR</button>
            </div>
          </div>
        </div>
      </header>

      <main class="content">
        <div class="hero-text">
          <a href="/" id="back" class="back-link">← назад</a>
          <h1 id="title">{pageTranslations.ru.title}</h1>
          <p id="subtitle" class="subtitle">{pageTranslations.ru.subtitle}</p>
        </div>

        <slot />
      </main>
    </div>

    <script define:vars={{ pageTranslations, navTranslations, appNavTranslations, isAppNav }}>
      const LANG_KEY = "lang";

      /** Case pages: [elementId, key on navTranslations[lang]] */
      const caseNavFields = [
        ["nav-home", "home"],
        ["nav-dakar", "dakar"],
        ["nav-bamako", "bamako"],
        ["nav-ouaga", "ouaga"],
        ["nav-niamey", "niamey"],
        ["nav-uav", "uav"],
        ["back", "back"]
      ];

      /** About / Biogeo / Humanitarian: [elementId, key on appNavTranslations[lang]] */
      const appNavFields = [
        ["nav-home", "home"],
        ["nav-about", "about"],
        ["nav-biogeo", "biogeo"],
        ["nav-humanitarian", "humanitarian"],
        ["back", "back"]
      ];

      function notifyLanguageChanged(lang) {
        window.dispatchEvent(new CustomEvent("languageChanged", { detail: { lang } }));
      }

      window.setLang = function (lang) {
        const nav = isAppNav ? appNavTranslations[lang] : navTranslations[lang];
        const page = pageTranslations[lang];
        if (!nav || !page) return;

        document.documentElement.lang = lang;
        document.title = page.title;

        const navFields = isAppNav ? appNavFields : caseNavFields;
        for (const [id, key] of navFields) {
          const el = document.getElementById(id);
          if (el) el.textContent = nav[key];
        }

        const titleEl = document.getElementById("title");
        const subtitleEl = document.getElementById("subtitle");
        if (titleEl) titleEl.textContent = page.title;
        if (subtitleEl) subtitleEl.textContent = page.subtitle;

        document.querySelectorAll(".lang button").forEach((btn) => {
          btn.classList.toggle("active", btn.dataset.lang === lang);
        });

        localStorage.setItem(LANG_KEY, lang);
        notifyLanguageChanged(lang);
      };

      window.setLang(localStorage.getItem(LANG_KEY) || "ru");
    </script>
  </body>
</html>
